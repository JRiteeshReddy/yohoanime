{
  "version": 2,

  "builds": [
    {
      "src": "providers/miruro/api.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],

  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
        "Access-Control-Allow-Headers": "Origin, X-Requested-With, Content-Type, Accept, Authorization"
      },
      "continue": true
    },
    {
      "src": "^/api/v2/miruro/(.*)$",
      "dest": "providers/miruro/api.py"
    },
    {
      "src": "^/(.*)$",
      "dest": "api/index.js"
    }
  ]
}
